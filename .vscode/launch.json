{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "AMD",
            "type": "debugpy",
            "request": "launch",
            "module": "amd.scrapers",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
